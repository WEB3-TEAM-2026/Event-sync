

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hash bcrypt
  name      String
  role      String   @default("ORGANIZER") // ORGANIZER uniquement pour cette version
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]

  @@map("users")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  startDate   DateTime
  endDate     DateTime
  location    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizerId String
  organizer   User      @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  sessions    Session[]

  @@map("events")
}

model Room {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]

  @@map("rooms")
}

model Speaker {
  id          String   @id @default(cuid())
  fullName    String
  profilePhoto String?  // URL de la photo
  bio         String   @db.Text
  externalLinks Json?   // Stockage des liens sociaux/web en JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions SessionSpeaker[]

  @@map("speakers")
}

model Session {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  startTime   DateTime
  endTime     DateTime
  capacity    Int?     // Capacité informative (non contraignante)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  speakers  SessionSpeaker[]
  questions Question[]

  @@map("sessions")
}

model SessionSpeaker {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  speakerId String
  speaker   Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, speakerId])
  @@map("session_speakers")
}

model Question {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorName String? // Optionnel pour permettre l'anonymat
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("questions")
}
